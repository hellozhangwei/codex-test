<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_account_asset_tree_inherit_number" model="ir.ui.view">
        <field name="name">account.asset.list.inherit.number</field>
        <field name="model">account.asset</field>
        <field name="inherit_id" ref="account_asset.view_account_asset_list"/>
        <field name="arch" type="xml">
            <xpath expr="//list/field[@name='name']" position="after">
                <field name="number"/>
            </xpath>
        </field>
    </record>

    <record id="view_account_asset_form_inherit_number" model="ir.ui.view">
        <field name="name">account.asset.form.inherit.number</field>
        <field name="model">account.asset</field>
        <field name="inherit_id" ref="account_asset.view_account_asset_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='name']" position="after">
                <field name="number"/>
            </xpath>
        </field>
    </record>
</odoo>
